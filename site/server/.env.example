# Required. Anthropic API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Port the Node service listens on (Caddy proxies to this).
PORT=8787

# Comma-separated allowed origins for CORS.
# Use exact origins, no trailing slash. Leave empty in dev to allow all.
ALLOWED_ORIGINS=https://crows.example.com

# Where the roster JSON lives (relative to server.js, or absolute).
ROSTER_PATH=../data/roster.json

# Per-IP rate limit on /api/oracle (requests per minute).
RATE_LIMIT_RPM=20

# Model to use. Override if you want a faster/cheaper option.
MODEL=claude-sonnet-4-20250514
